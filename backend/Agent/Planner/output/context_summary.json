  "decision_rules": {
    "budget_planning": [
      {
        "rule_id": "BR-001",
        "condition": "expected_participants < reliable_prediction_floor",
        "action": "Use budget floor, flag LOW confidence",
        "confidence_output": "LOW"
      },
      {
        "rule_id": "BR-002",
        "condition": "normal range",
        "action": "Apply linear regression Budget = 5 x P + 750",
        "confidence_output": "HIGH"
      },
      {
        "rule_id": "BR-003",
        "condition": "expected_participants > max",
        "action": "Apply regression + 15% buffer",
        "confidence_output": "MEDIUM"
      },
      {
        "rule_id": "BR-004",
        "condition": "budget_requested < floor_value",
        "action": "Reject, return minimum viable budget",
        "confidence_output": "BLOCKED"
      }
    ],
    "scheduling": [
      {
        "rule_id": "SR-001",
        "condition": "month in exam_risk_months",
        "action": "Warn user, suggest next clear month",
        "severity": "HIGH"
      },
      {
        "rule_id": "SR-002",
        "condition": "high_priority_meetings >= 4",
        "action": "Flag conflict, offer alternative",
        "severity": "MEDIUM"
      },
      {
        "rule_id": "SR-003",
        "condition": "avg_satisfaction < 2.5",
        "action": "Discourage, explain poor history",
        "severity": "MEDIUM"
      },
      {
        "rule_id": "SR-004",
        "condition": "same category in same month",
        "action": "Warn audience fatigue",
        "severity": "LOW"
      }
    ],
    "risk_mitigation": [
      {
        "rule_id": "RR-001",
        "issue": "WiFi",
        "trigger_threshold_pct": 40,
        "auto_recommendation": "Pre-book dedicated WiFi network 72 hours before event",
        "escalation": "Contact IT department for bandwidth reservation"
      },
      {
        "rule_id": "RR-002",
        "issue": "Logistics",
        "trigger_threshold_pct": 40,
        "auto_recommendation": "Assign dedicated logistics coordinator 48 hours before",
        "escalation": "Create logistics checklist and assign to bureau member"
      },
      {
        "rule_id": "RR-003",
        "issue": "Timing",
        "trigger_threshold_pct": 30,
        "auto_recommendation": "Schedule event start 30 min earlier than planned",
        "escalation": "Send reminder notifications 24h and 1h before"
      },
      {
        "rule_id": "RR-004",
        "issue": "Crowd",
        "trigger_threshold_pct": 30,
        "auto_recommendation": "Prepare overflow space or limit registration",
        "escalation": "Set hard cap at max_reliable_participants for venue"
      }
    ]
